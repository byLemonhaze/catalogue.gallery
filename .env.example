VITE_SANITY_PROJECT_ID=your_sanity_project_id
VITE_SANITY_DATASET=production

# Local scripts (never commit real values)
SANITY_WRITE_TOKEN=your_sanity_write_token

# Cloudflare Functions / server-side
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=CATALOGUE <apply@catalogue.gallery>
RESEND_REPLY_TO=yourname@proton.me
PUBLIC_BASE_URL=https://catalogue.gallery
# Optional: Cloudflare Web Analytics token (manual beacon mode)
VITE_CF_WEB_ANALYTICS_TOKEN=
WEBHOOK_SHARED_SECRET=set_a_long_random_secret
# 32-byte random key, base64-encoded. Used to encrypt contact emails at rest in Sanity.
# Example generation: `openssl rand -base64 32`
EMAIL_ENCRYPTION_KEY=base64_32_byte_key

# Cloudflare D1 private contacts are configured as a binding (not env var):
# binding name: CONTACTS_DB
